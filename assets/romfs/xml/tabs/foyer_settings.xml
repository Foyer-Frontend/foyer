<!--
    foyer Settings — HOS-style sidebar layout.

    brls::TabFrame renders a vertical sidebar of category labels on
    the left and the focused category's content on the right.
    Each <brls:Tab> maps to a registered C++ class — every tab
    builds its own rows in its constructor (Cores tab populates
    from the live manifest, Updates tab spawns an update job, etc.)
    so the panels stay live with their data.
-->
<brls:AppletFrame
    iconInterpolation="linear"
    footerHidden="false"
    title="Foyer settings">

    <brls:TabFrame
        title="Foyer settings">

        <brls:Tab label="General">
            <FoyerGeneralTab />
        </brls:Tab>

        <brls:Tab label="Online accounts">
            <FoyerAccountsTab />
        </brls:Tab>

        <brls:Tab label="Library">
            <FoyerLibraryTab />
        </brls:Tab>

        <brls:Tab label="Cores">
            <FoyerCoresTab />
        </brls:Tab>

        <brls:Tab label="Updates">
            <FoyerUpdatesTab />
        </brls:Tab>

        <brls:Separator />

        <brls:Tab label="About">
            <FoyerAboutTab />
        </brls:Tab>

    </brls:TabFrame>

</brls:AppletFrame>
