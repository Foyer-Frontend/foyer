<!--
    foyer System view — borealis edition.

    Mirrors home.xml's HOS-style stacking: status cluster top-right,
    cover-flow carousel vertically centred, system-specific round
    action buttons (Scrape, Scan, Search, Settings) tucked directly
    under the carousel. Hint bar pinned to the bottom.

    SystemActivity populates foyer/logo_holder, foyer/action_row and
    foyer/carousel from the focused system's data; the backdrop
    Image is set from `themes/foyer/systems/<folder>/background.jpg`
    in onContentAvailable().
-->
<brls:Box
    width="auto"
    height="auto"
    grow="1.0"
    axis="column">

    <!-- Per-system app backdrop — same crop as Home. -->
    <brls:Image
        id="foyer/backdrop"
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        width="1280"
        height="720"
        scalingType="fill" />

    <!-- Top bar — system logo on the left, clock / wifi / battery
         on the right (mirrors home.xml's chrome placement). -->
    <brls:Box
        id="foyer/top_bar"
        width="auto"
        height="80"
        axis="row"
        alignItems="center"
        backgroundColor="@theme/foyer/bar_overlay"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides">

        <brls:Box
            id="foyer/logo_holder"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

        <brls:Box width="auto" height="auto" grow="1.0" />

        <brls:Box
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            direction="leftToRight">

            <brls:Label
                id="foyer/clock"
                text="--:--"
                width="auto"
                height="auto"
                fontSize="22"
                marginRight="20" />

            <brls:Wireless
                id="foyer/wireless"
                marginRight="20"
                marginBottom="2" />

            <brls:Battery
                id="foyer/battery"
                marginBottom="2" />
        </brls:Box>
    </brls:Box>

    <!-- Upper flex spacer — biases carousel + action row toward
         upper-middle to match home.xml. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="2.0" />

    <!-- Game cover-flow carousel — vertically centred, action row
         directly underneath. -->
    <brls:HScrollingFrame
        id="foyer/carousel_scroll"
        width="100%"
        height="320"
        scrollingBehavior="centered">

        <brls:Box
            id="foyer/carousel"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            justifyContent="center"
            paddingLeft="48"
            paddingRight="48" />

    </brls:HScrollingFrame>

    <!-- Action row — system-specific buttons (Scrape, Scan,
         Per-system settings). Pinned directly under the carousel. -->
    <brls:Box
        width="auto"
        height="auto"
        axis="row"
        alignItems="center"
        justifyContent="center"
        marginTop="24"
        marginBottom="16">

        <brls:Box
            id="foyer/action_row"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

    </brls:Box>

    <!-- Lower flex spacer. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="1.0" />

    <!-- Bottom bar — scrape progress label on the left, brls
         button hints on the right. -->
    <brls:Box
        id="foyer/bottom_bar"
        width="auto"
        height="@style/brls/applet_frame/footer_height"
        axis="row"
        alignItems="center"
        backgroundColor="@theme/foyer/bar_overlay"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides"
        paddingTop="@style/brls/hints/footer_padding_top_bottom"
        paddingBottom="@style/brls/hints/footer_padding_top_bottom">

        <brls:Label
            id="foyer/scrape_status"
            text=""
            width="auto"
            height="auto"
            fontSize="18" />

        <brls:Box width="auto" height="auto" grow="1.0" />

        <brls:Hints
            width="auto"
            height="auto" />

    </brls:Box>

</brls:Box>
