<!--
    foyer Downloads — full-screen content download hub.

    Same chrome shell as Settings (top bar with clock · wifi · battery)
    but the body's TabFrame holds only the four manifest categories.
    Pushed by FoyerDownloadsTab's landing page when the user presses A,
    so the original Settings sidebar is hidden while the user is in
    here — no more double-sidebar layout.

    A footer hint "Download queue" routes to DownloadQueueActivity so
    the user can review pending / running installs without going back
    to Settings.
-->
<brls:AppletFrame
    headerHidden="true"
    iconInterpolation="linear">

    <brls:Box
        width="auto"
        height="auto"
        grow="1.0"
        axis="column">

        <!-- Top bar — same shape as Settings + Home for chrome
             consistency. -->
        <brls:Box
            width="auto"
            height="80"
            axis="row"
            alignItems="center"
            marginLeft="@style/brls/hints/footer_margin_sides"
            marginRight="@style/brls/hints/footer_margin_sides"
            paddingLeft="@style/brls/hints/footer_padding_sides"
            paddingRight="@style/brls/hints/footer_padding_sides">

            <brls:Label
                text="Downloads"
                width="auto"
                height="auto"
                fontSize="22"
                textColor="@theme/brls/text" />

            <brls:Box width="auto" height="auto" grow="1.0" />

            <brls:Box
                width="auto"
                height="auto"
                axis="row"
                alignItems="center"
                direction="leftToRight">

                <brls:Label
                    id="foyer/clock"
                    text="--:--"
                    width="auto"
                    height="auto"
                    fontSize="22"
                    marginRight="20" />

                <brls:Wireless
                    id="foyer/wireless"
                    marginRight="20"
                    marginBottom="2" />

                <brls:Battery
                    id="foyer/battery"
                    marginBottom="2" />
            </brls:Box>
        </brls:Box>

        <brls:TabFrame
            grow="1.0"
            title="Downloads">

            <brls:Tab label="Cores">
                <FoyerCoresTab />
            </brls:Tab>

            <brls:Tab label="Bezels">
                <FoyerBezelsTab />
            </brls:Tab>

            <brls:Tab label="Shaders">
                <FoyerShadersTab />
            </brls:Tab>

            <brls:Tab label="Cheats">
                <FoyerCheatsTab />
            </brls:Tab>

        </brls:TabFrame>
    </brls:Box>

</brls:AppletFrame>
