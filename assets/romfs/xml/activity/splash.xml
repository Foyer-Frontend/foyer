<!--
    foyer Splash — pixel-art background + theme-aware overlay so
    boot is on-brand instead of a flat panel. The SplashActivity
    fills the ProgressBar fill (id=foyer/splash_bar_fill) as the
    worker advances through manifest steps, and writes per-step
    text into id=foyer/splash_status.
-->
<brls:Box
    width="auto"
    height="auto"
    grow="1.0"
    axis="column"
    alignItems="center"
    justifyContent="center"
    backgroundColor="@theme/brls/background">

    <brls:Image
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        width="1280"
        height="720"
        scalingType="fill"
        image="@res/splash.png" />

    <!--
        Theme-aware dim. Both dark and light theme variants of
        @theme/brls/background are translucent enough at 65% to let
        the pixel-art read through, while ensuring the brand label
        and bar stay legible.
    -->
    <brls:Rectangle
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        width="1280"
        height="720"
        color="@theme/foyer/splash_overlay" />

    <brls:Label
        text="foyer"
        width="auto"
        height="auto"
        fontSize="72"
        marginBottom="32"
        textColor="@theme/brls/text" />

    <!--
        ProgressBar (manually constructed — brls only ships
        ProgressSpinner). Track is a fixed-width Box; the inner
        fill widens as the splash worker reports progress.
    -->
    <brls:Box
        width="520"
        height="14"
        cornerRadius="7"
        backgroundColor="@theme/foyer/splash_bar_track"
        axis="row"
        alignItems="center"
        marginBottom="20">

        <brls:Box
            id="foyer/splash_bar_fill"
            width="0"
            height="14"
            cornerRadius="7"
            backgroundColor="@theme/foyer/splash_bar_fill" />
    </brls:Box>

    <brls:Label
        id="foyer/splash_status"
        text="Loading…"
        width="auto"
        height="auto"
        fontSize="22"
        textColor="@theme/brls/text" />

    <!--
        Build label pinned to the bottom-right corner. Populated at
        runtime from FOYER_DISPLAY_VERSION (version + short git
        commit). Single point of presence so the user can quickly
        confirm which build is running while crashes are being
        diagnosed.
    -->
    <brls:Label
        id="foyer/splash_build"
        text=""
        positionType="absolute"
        positionRight="20"
        positionBottom="14"
        fontSize="16"
        textColor="@theme/brls/text" />

</brls:Box>
