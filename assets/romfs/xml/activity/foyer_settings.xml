<!--
    foyer Settings — HOS-style sidebar layout via brls TabFrame.

    Top bar mirrors Home / System / Game (clock · wifi · battery)
    so the chrome looks consistent across every screen. AppletFrame's
    own header is hidden via headerHidden=true; we keep its footer
    (BottomBar) so brls's hint pills still show under each tab.

    Each <brls:Tab> resolves to a registered C++ view name, defined
    in browser/src/settings_tab.cpp.
-->
<brls:AppletFrame
    headerHidden="true"
    iconInterpolation="linear">

    <brls:Box
        width="auto"
        height="auto"
        grow="1.0"
        axis="column">

        <!-- Top bar — clock · wifi · battery cluster pushed right
             by a flex-grow spacer. Same heights/margins as
             home.xml so the chrome reads identical. -->
        <brls:Box
            width="auto"
            height="80"
            axis="row"
            alignItems="center"
            marginLeft="@style/brls/hints/footer_margin_sides"
            marginRight="@style/brls/hints/footer_margin_sides"
            paddingLeft="@style/brls/hints/footer_padding_sides"
            paddingRight="@style/brls/hints/footer_padding_sides">

            <brls:Label
                text="Settings"
                width="auto"
                height="auto"
                fontSize="22"
                textColor="@theme/brls/text" />

            <brls:Box width="auto" height="auto" grow="1.0" />

            <brls:Box
                width="auto"
                height="auto"
                axis="row"
                alignItems="center"
                direction="leftToRight">

                <brls:Label
                    id="foyer/clock"
                    text="--:--"
                    width="auto"
                    height="auto"
                    fontSize="22"
                    marginRight="20" />

                <brls:Wireless
                    id="foyer/wireless"
                    marginRight="20"
                    marginBottom="2" />

                <brls:Battery
                    id="foyer/battery"
                    marginBottom="2" />
            </brls:Box>
        </brls:Box>

        <brls:TabFrame
            grow="1.0"
            title="@i18n/foyer/settings/title">

            <brls:Tab label="General">
                <FoyerGeneralTab />
            </brls:Tab>

            <brls:Tab label="Online accounts">
                <FoyerAccountsTab />
            </brls:Tab>

            <brls:Tab label="Library">
                <FoyerLibraryTab />
            </brls:Tab>

            <brls:Tab label="Downloads">
                <FoyerDownloadsTab />
            </brls:Tab>

            <brls:Tab label="Emulators">
                <FoyerEmulatorsTab />
            </brls:Tab>

            <brls:Tab label="Updates">
                <FoyerUpdatesTab />
            </brls:Tab>

            <brls:Separator />

            <brls:Tab label="About">
                <FoyerAboutTab />
            </brls:Tab>

        </brls:TabFrame>
    </brls:Box>

</brls:AppletFrame>
