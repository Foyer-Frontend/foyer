<!--
    foyer Home — borealis edition.

    Top bar: profile placeholder · spacer · status cluster
    (clock · wifi · battery, top-right).

    Centre: horizontal system carousel populated by
    HomeActivity::onContentAvailable() from foyer's system_db.

    Below the carousel: HOS-style round action row. Phase B ships
    only Settings; News / eShop / Album / Controllers / Power land
    in alpha.11+ when their handlers exist.

    The full-screen Image at the back is the per-system backdrop —
    HomeActivity swaps its source on tile focus changes so the
    backdrop matches the system the user is hovering.
-->
<brls:Box
    width="auto"
    height="auto"
    grow="1.0"
    axis="column">

    <!-- Per-system app backdrop — absolute-positioned behind every
         other view; updated by HomeActivity on tile focus change. -->
    <brls:Image
        id="foyer/backdrop"
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        width="1280"
        height="720"
        scalingType="fill" />

    <!-- Top bar -->
    <brls:Box
        width="auto"
        height="80"
        axis="row"
        alignItems="center"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides">

        <!-- Profile cluster placeholder (Phase F wires real avatars). -->
        <brls:Box
            id="foyer/profiles"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

        <brls:Box width="auto" height="auto" grow="1.0" />

        <!-- Status cluster: clock · wifi · battery (left → right) -->
        <brls:Box
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            direction="leftToRight">

            <brls:Label
                id="foyer/clock"
                text="--:--"
                width="auto"
                height="auto"
                fontSize="22"
                marginRight="20" />

            <brls:Wireless
                id="foyer/wireless"
                marginRight="20"
                marginBottom="2" />

            <brls:Battery
                id="foyer/battery"
                marginBottom="2" />
        </brls:Box>
    </brls:Box>

    <!-- System carousel — vertically centred in the available
         space between top bar and the action row. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="1.0"
        axis="column"
        justifyContent="center">

        <brls:HScrollingFrame
            id="foyer/carousel_scroll"
            width="auto"
            height="320"
            scrollingBehavior="centered">

            <brls:Box
                id="foyer/carousel"
                width="auto"
                height="auto"
                axis="row"
                paddingLeft="48"
                paddingRight="48" />

        </brls:HScrollingFrame>

    </brls:Box>

    <!-- HOS-style round action row, centred horizontally. The
         Settings circle is built programmatically in HomeActivity
         (round corner-radius + click handler that pushes
         SettingsActivity). -->
    <brls:Box
        width="auto"
        height="96"
        axis="row"
        alignItems="center"
        justifyContent="center"
        paddingTop="8"
        paddingBottom="8">

        <brls:Box
            id="foyer/action_row"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

    </brls:Box>

    <!-- Bottom hint bar — separator line on top + brls Hints (the
         controller button hints, e.g. A: OK, B: Back). Mirrors the
         AppletFrame's BottomBar but without its built-in
         clock/wifi/battery cluster (foyer puts those in the top bar
         per HOS launcher convention). -->
    <brls:Box
        width="auto"
        height="@style/brls/applet_frame/footer_height"
        axis="row"
        alignItems="center"
        justifyContent="flexEnd"
        marginLeft="@style/brls/hints/footer_margin_sides"
        marginRight="@style/brls/hints/footer_margin_sides"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides"
        paddingTop="@style/brls/hints/footer_padding_top_bottom"
        paddingBottom="@style/brls/hints/footer_padding_top_bottom"
        lineColor="@theme/brls/applet_frame/separator"
        lineTop="1px">

        <brls:Hints
            width="auto"
            height="auto" />

    </brls:Box>

</brls:Box>
