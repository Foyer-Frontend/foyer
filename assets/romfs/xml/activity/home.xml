<!--
    foyer Home — borealis edition.

    Top bar: profile placeholder · spacer · status cluster
    (clock · wifi · battery, top-right).

    Centre: horizontal system carousel populated by
    HomeActivity::onContentAvailable() from foyer's system_db.

    Below the carousel: HOS-style round action row. Phase B ships
    only Settings; News / eShop / Album / Controllers / Power land
    in alpha.11+ when their handlers exist.

    The full-screen Image at the back is the per-system backdrop —
    HomeActivity swaps its source on tile focus changes so the
    backdrop matches the system the user is hovering.
-->
<brls:Box
    width="auto"
    height="auto"
    grow="1.0"
    axis="column">

    <!-- Per-system app backdrop — absolute-positioned in the
         middle band between the top status bar (80 px) and the
         bottom hint bar (footer_height = 73 px) so the bars never
         draw on top of it. Updated by HomeActivity on tile focus
         change. -->
    <brls:Image
        id="foyer/backdrop"
        positionType="absolute"
        positionTop="80"
        positionLeft="0"
        width="1280"
        height="567"
        scalingType="fill" />

    <!-- Top bar — backdrop already provides visual separation, so
         no divider line. -->
    <brls:Box
        width="auto"
        height="80"
        axis="row"
        alignItems="center"
        marginLeft="@style/brls/hints/footer_margin_sides"
        marginRight="@style/brls/hints/footer_margin_sides"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides">

        <!-- Profile cluster placeholder (Phase F wires real avatars). -->
        <brls:Box
            id="foyer/profiles"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

        <brls:Box width="auto" height="auto" grow="1.0" />

        <!-- Status cluster: clock · wifi · battery (left → right) -->
        <brls:Box
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            direction="leftToRight">

            <brls:Label
                id="foyer/clock"
                text="--:--"
                width="auto"
                height="auto"
                fontSize="22"
                marginRight="20" />

            <brls:Wireless
                id="foyer/wireless"
                marginRight="20"
                marginBottom="2" />

            <brls:Battery
                id="foyer/battery"
                marginBottom="2" />
        </brls:Box>
    </brls:Box>

    <!-- HOS-style round action buttons — pinned just below the top
         bar's separator. Populated by HomeActivity. -->
    <brls:Box
        width="auto"
        height="auto"
        axis="row"
        alignItems="center"
        justifyContent="center"
        marginTop="16"
        marginBottom="16">

        <brls:Box
            id="foyer/action_row"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

    </brls:Box>

    <!-- Empty middle band — backdrop shows through. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="1.0" />

    <!-- System carousel — pinned just above the bottom hint bar. -->
    <brls:HScrollingFrame
        id="foyer/carousel_scroll"
        width="100%"
        height="264"
        marginBottom="8"
        scrollingBehavior="centered">

        <brls:Box
            id="foyer/carousel"
            width="auto"
            height="auto"
            axis="row"
            alignItems="flexEnd"
            paddingLeft="48"
            paddingRight="48" />

    </brls:HScrollingFrame>

    <!-- Bottom hint bar — brls Hints (the controller button hints,
         e.g. A: OK, B: Back). No top divider; the backdrop bands
         provide the visual separation. -->
    <brls:Box
        width="auto"
        height="@style/brls/applet_frame/footer_height"
        axis="row"
        alignItems="center"
        justifyContent="flexEnd"
        marginLeft="@style/brls/hints/footer_margin_sides"
        marginRight="@style/brls/hints/footer_margin_sides"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides"
        paddingTop="@style/brls/hints/footer_padding_top_bottom"
        paddingBottom="@style/brls/hints/footer_padding_top_bottom">

        <brls:Hints
            width="auto"
            height="auto" />

    </brls:Box>

</brls:Box>
