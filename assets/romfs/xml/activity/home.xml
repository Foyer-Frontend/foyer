<!--
    foyer Home — borealis edition.

    Top bar: profile placeholder · Settings button · spacer · status
    cluster (clock · wifi · battery, top-right).

    Centre: horizontal system carousel (Phase C). Populated in
    HomeActivity::onContentAvailable() from foyer's system_db so
    the data side is decoupled from XML.
-->
<brls:Box
    width="auto"
    height="auto"
    grow="1.0"
    axis="column">

    <!-- Top bar -->
    <brls:Box
        width="auto"
        height="80"
        axis="row"
        alignItems="center"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides">

        <!-- Profile cluster placeholder (Phase F wires real avatars). -->
        <brls:Box
            id="foyer/profiles"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

        <brls:Box width="auto" height="auto" grow="1.0" />

        <!-- Settings button — clicking pushes SettingsActivity. -->
        <brls:Box
            id="foyer/btn_settings"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            focusable="true"
            highlightCornerRadius="4"
            marginRight="20">

            <brls:Label
                text="@i18n/foyer/actions/open_settings"
                fontSize="22" />
        </brls:Box>

        <!-- Status cluster: clock · wifi · battery (left → right) -->
        <brls:Box
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            direction="leftToRight">

            <brls:Label
                id="foyer/clock"
                text="--:--"
                width="auto"
                height="auto"
                fontSize="22"
                marginRight="20" />

            <brls:Wireless
                id="foyer/wireless"
                marginRight="20"
                marginBottom="2" />

            <brls:Battery
                id="foyer/battery"
                marginBottom="2" />
        </brls:Box>
    </brls:Box>

    <!-- System carousel — vertically centred between top bar and the
         bottom edge. HScrollingFrame is brls's horizontal-only scroller
         (the plain ScrollingFrame is vertical even with axis="row");
         it auto-scrolls to keep the focused child centred. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="1.0"
        axis="column"
        justifyContent="center">

        <brls:HScrollingFrame
            id="foyer/carousel_scroll"
            width="auto"
            height="240"
            scrollingBehavior="centered">

            <brls:Box
                id="foyer/carousel"
                width="auto"
                height="auto"
                axis="row"
                alignItems="center"
                paddingLeft="32"
                paddingRight="32" />

        </brls:HScrollingFrame>

    </brls:Box>

</brls:Box>
