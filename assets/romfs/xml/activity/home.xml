<!--
    foyer Home — borealis edition.

    Switch-Home-style layout: per-system backdrop full-screen,
    minimal top bar (profile + status), then carousel of system
    tiles sitting just above the vertical centre with the round
    action buttons (Settings · Power) tucked directly underneath
    (mirrors HOS's "row of game tiles, action row immediately
    below" stacking). Hint bar pinned to the bottom.

    HomeActivity populates foyer/profiles, foyer/focus_logo,
    foyer/carousel and foyer/action_row from system_db on
    onContentAvailable(); the backdrop Image swaps as the user
    scrolls the carousel.
-->
<brls:Box
    width="auto"
    height="auto"
    grow="1.0"
    axis="column">

    <!-- Per-system app backdrop — full-screen so the translucent
         bar overlays (top 80 px, bottom ~73 px) have something to
         tint. Updated by HomeActivity on tile focus change. -->
    <brls:Image
        id="foyer/backdrop"
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        width="1280"
        height="720"
        scalingType="fill" />

    <!-- Top bar — backdrop already provides visual separation, so
         no divider line. -->
    <brls:Box
        width="auto"
        height="80"
        axis="row"
        alignItems="center"
        backgroundColor="@theme/foyer/bar_overlay"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides">

        <!-- Profile cluster placeholder (Phase F wires real avatars). -->
        <brls:Box
            id="foyer/profiles"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

        <!-- Focused-system logo — fills in as the user scrolls the
             carousel. HomeActivity::onSystemFocused points at
             theme/foyer/systems/<folder>/logo_(dark|light).png. -->
        <brls:Image
            id="foyer/focus_logo"
            width="auto"
            height="56"
            marginLeft="20"
            scalingType="fit" />

        <brls:Box width="auto" height="auto" grow="1.0" />

        <!-- Status cluster: clock · wifi · battery (left → right) -->
        <brls:Box
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            direction="leftToRight">

            <brls:Label
                id="foyer/clock"
                text="--:--"
                width="auto"
                height="auto"
                fontSize="22"
                marginRight="20" />

            <brls:Wireless
                id="foyer/wireless"
                marginRight="20"
                marginBottom="2" />

            <brls:Battery
                id="foyer/battery"
                marginBottom="2" />
        </brls:Box>
    </brls:Box>

    <!-- Upper flex spacer — biases the carousel + action-row stack
         toward the vertical middle. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="1.0" />

    <!-- System carousel — centred with the action row directly
         underneath. The HScrollingFrame's `scrollingBehavior=
         centered` keeps the focused tile horizontally anchored
         once a child has focus; paddingLeft / paddingRight on the
         inner box give the row enough breathing space for the
         centred slot to actually slide on either side of focus. -->
    <brls:HScrollingFrame
        id="foyer/carousel_scroll"
        width="100%"
        height="280"
        scrollingBehavior="centered">

        <brls:Box
            id="foyer/carousel"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center"
            justifyContent="center"
            paddingLeft="520"
            paddingRight="520" />

    </brls:HScrollingFrame>

    <!-- HOS-style round action buttons — pinned directly below the
         carousel so the eye flow is tile → action. -->
    <brls:Box
        width="auto"
        height="auto"
        axis="row"
        alignItems="center"
        justifyContent="center"
        marginTop="24"
        marginBottom="16">

        <brls:Box
            id="foyer/action_row"
            width="auto"
            height="auto"
            axis="row"
            alignItems="center" />

    </brls:Box>

    <!-- Lower flex spacer. -->
    <brls:Box
        width="auto"
        height="auto"
        grow="1.0" />

    <!-- Bottom hint bar — brls Hints (controller button hints). -->
    <brls:Box
        width="auto"
        height="@style/brls/applet_frame/footer_height"
        axis="row"
        alignItems="center"
        justifyContent="flexEnd"
        backgroundColor="@theme/foyer/bar_overlay"
        paddingLeft="@style/brls/hints/footer_padding_sides"
        paddingRight="@style/brls/hints/footer_padding_sides"
        paddingTop="@style/brls/hints/footer_padding_top_bottom"
        paddingBottom="@style/brls/hints/footer_padding_top_bottom">

        <brls:Hints
            width="auto"
            height="auto" />

    </brls:Box>

</brls:Box>
